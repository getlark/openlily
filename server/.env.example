# openlily - Environment Variables
# Copy this file to .env and fill in only what your setup needs.
#
# Variables are grouped by WHEN you need them:
#   [REQUIRED]  always needed (any brain)
#   [BRAIN]     needed only for a specific brain (see each note)
#   [TOOL]      needed only if you enable that tool (tools are opt-in)
#   [OPTIONAL]  tuning; safe to leave as-is

# =============================================================================
# [REQUIRED] - always set this
# =============================================================================

# OpenAI API key. Every brain uses the OpenAI LLM (and the all-OpenAI brain uses
# OpenAI STT/TTS too), so this is required no matter how you configure openlily.
OPENAI_API_KEY=

# =============================================================================
# [BRAIN] - set based on the brain you run (brains.yaml -> default_brain)
# =============================================================================

# Cartesia API key (ink-2 STT + sonic-3.5 TTS). REQUIRED for the default brain,
# "cartesia_openai" (and for "cartesia_meta", which reuses Cartesia STT/TTS).
# Leave blank if you switch default_brain to "openai_standard" or
# "openai_realtime" (neither uses Cartesia).
CARTESIA_API_KEY=

# Meta Model API key (https://ai.developer.meta.com; Meta's docs call this
# MODEL_API_KEY). REQUIRED only for the "cartesia_meta" brain, whose LLM
# (muse-spark-1.1) is served by Meta's OpenAI-compatible endpoint
# (https://api.meta.ai/v1). That brain still uses Cartesia for STT/TTS, so it
# needs CARTESIA_API_KEY above too. Leave blank if you don't run the
# cartesia_meta brain.
META_API_KEY=

# =============================================================================
# [TOOL] - set only if you enable the matching tool. Optional generic tools are
#          turned on by name in the 'tools' list in brains.yaml (browser, email,
#          notion, x); the end-session tool is always on. A tool enabled there requires
#          its credentials below -- enabling one without them fails at startup.
# =============================================================================

# Web search (Exa). Needed ONLY by the "openai_realtime" brain's web search.
# The cascade brains (openai_standard, cartesia_openai) use OpenAI's built-in
# web search instead, and "cartesia_meta" uses Meta's hosted search grounding
# (both server-side, billed under their own API keys), so none of them need this.
# Leave blank if you don't run the realtime brain, or don't want it to search the
# web.
EXA_API_KEY=

# Email tool (Resend; tools/email/). All three are required TOGETHER for the
# email tool to wire up; leave them blank/commented to run without it.
#   USER_EMAIL     -> the recipient: your own address (the bot only emails you).
#   RESEND_API_KEY -> your Resend API key.
#   EMAIL_FROM     -> a sender address on a domain verified with Resend.
# USER_EMAIL=
# RESEND_API_KEY=
# EMAIL_FROM=

# X / Twitter tool (X's hosted MCP; tools/x/). Set this to your X app's App-only
# Bearer token (X developer portal -> your app -> "Keys and tokens"). Enables
# read-only search/lookup of posts, users, trends, and news via
# https://api.x.com/mcp -- no local bridge or OAuth login. When unset, the X
# tool is skipped and the session still runs.
# X_APP_BEARER_TOKEN=

# Notion tool (official Notion MCP; tools/notion/). Set this to your Notion
# internal integration token (https://www.notion.so/profile/integrations).
# Connect pages and databases to the integration before the agent can access
# them. Requires Node.js/npx on the host. When unset, the Notion tool is
# skipped and the session still runs.
# NOTION_ACCESS_TOKEN=

# Browser tool (Playwright MCP). Needs Node.js/npx. Instead of launching its own
# browser, the tool attaches to an already-running one over the Chrome DevTools
# Protocol, so the browser persists across sessions (idle timeout tears down the
# session, not the browser; the next session reconnects). REQUIRED to enable the
# tool: set it to the CDP endpoint of a browser you launched yourself, e.g.
# Chrome started with --remote-debugging-port=9222. When unset, the browser tool
# is skipped. The external browser owns its profile, so there's no user-data-dir.
# BROWSER_CDP_ENDPOINT=http://localhost:9222

# =============================================================================
# [OPTIONAL] - tuning; safe to leave as-is
# =============================================================================

# Seconds of silence (no user or bot speech) before the session ends and the
# process exits. In wake-word mode, that exit is what lets the detector resume
# listening for the next wake word. Defaults to 30 if unset (or unparseable).
IDLE_TIMEOUT_SECS=30

# Wake word(s) for --mode local-with-wake-word. Comma-separated openWakeWord
# model names or paths to .onnx/.tflite models. Defaults to "alexa". List
# several to accept any of them (e.g. WAKE_MODELS=alexa,hey_jarvis).
# Available pretrained wake phrases:
#   alexa        -> say "Alexa"
#   hey_jarvis   -> say "Hey Jarvis"
#   hey_mycroft  -> say "Hey Mycroft"
#   hey_rhasspy  -> say "Hey Rhasspy"
# WAKE_MODELS=alexa

# Wake-word barge-in. In the local voice CLI the mic is half-duplex gated while
# the bot speaks, so it can't be interrupted mid-utterance. Set this to "true"
# to let the wake word (WAKE_MODELS above) cut the bot off. The gate exists
# because on one device the mic hears the bot's own voice; on headphones there's
# no such echo, so this is safe to enable. Off unless set to "true".
# WAKE_WORD_BARGE_IN=true

# Tool-call debug dump. Tool calls are always logged (truncated) to the console;
# set this to a directory to ALSO dump full, untruncated tool calls and their
# results as structured JSONL. Each session writes its own file
# (tool-calls-<timestamp>-<id>.jsonl), created only once a session actually makes
# a tool call. Purely a debug aid: unset by default, and a write error never
# disrupts the session. The directory is created if it doesn't exist.
# TOOL_CALL_DEBUG_DIR=./tool-call-logs
